{
    "compilerOptions": {
        "module": "node16",
        "moduleResolution": "node16",
        "target": "ES2020",
        "lib": ["ES2020"],
        "outDir": "./out",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "types": ["node"],
        "sourceMap": true,
        "paths": {
            "@/*": ["./webview/*"],
            "@/i18n": ["./webview/i18n"]
        }
    },
    "include": ["src/**/*.ts", "shared/**/*.ts"],
    "exclude": ["node_modules", "dist", "webview"]
}
