{
  "name": "markdown-writer",
  "displayName": "Markdown Writer",
  "description": "Markdown Writer: a WYSIWYG Markdown editor with live table editing",
  "version": "0.2.40",
  "publisher": "harlanlewis",
  "engines": {
    "vscode": "^1.80.0"
  },
  "packageManager": "pnpm@10.6.1",
  "extensionKind": [
    "workspace",
    "ui"
  ],
  "icon": "images/icon.jpg",
  "categories": [
    "Formatters",
    "Other"
  ],
  "keywords": [
    "markdown",
    "wysiwyg",
    "editor",
    "table",
    "milkdown"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/harlanlewis/markdown-writer.git"
  },
  "bugs": {
    "url": "https://github.com/harlanlewis/markdown-writer/issues"
  },
  "homepage": "https://github.com/harlanlewis/markdown-writer#readme",
  "activationEvents": [],
  "main": "./dist/extension.js",
  "l10n": "./l10n",
  "contributes": {
    "customEditors": [
      {
        "viewType": "markdownWriter.editor",
        "displayName": "Markdown Writer",
        "selector": [
          {
            "filenamePattern": "*.md"
          },
          {
            "filenamePattern": "*.markdown"
          }
        ],
        "priority": "option"
      }
    ],
    "commands": [
      {
        "command": "markdownWriter.switchToTextEditor",
        "title": "%command.switchToTextEditor.title%",
        "icon": "$(eye-closed)"
      },
      {
        "command": "markdownWriter.switchToPreview",
        "title": "%command.switchToPreview.title%",
        "icon": "$(eye)"
      },
      {
        "command": "markdownWriter.debugModeEnable",
        "title": "%command.debugModeEnable.title%"
      },
      {
        "command": "markdownWriter.debugModeDisable",
        "title": "%command.debugModeDisable.title%"
      },
      {
        "command": "markdownWriter.selectTheme",
        "title": "%command.selectTheme.title%"
      },
      {
        "command": "markdownWriter.showCurrentTheme",
        "title": "%command.showCurrentTheme.title%"
      },
      {
        "command": "markdownWriter.toggleStyleCheck",
        "title": "%command.toggleStyleCheck.title%"
      },
      {
        "command": "markdownWriter.gotoSymbol",
        "title": "%command.gotoSymbol.title%"
      },
      {
        "command": "markdownWriter.editor.toggleBold",
        "title": "%command.editor.toggleBold.title%",
        "category": "Markdown Writer"
      },
      {
        "command": "markdownWriter.editor.toggleItalic",
        "title": "%command.editor.toggleItalic.title%",
        "category": "Markdown Writer"
      },
      {
        "command": "markdownWriter.editor.toggleStrikethrough",
        "title": "%command.editor.toggleStrikethrough.title%",
        "category": "Markdown Writer"
      },
      {
        "command": "markdownWriter.editor.toggleInlineCode",
        "title": "%command.editor.toggleInlineCode.title%",
        "category": "Markdown Writer"
      },
      {
        "command": "markdownWriter.editor.clearFormatting",
        "title": "%command.editor.clearFormatting.title%",
        "category": "Markdown Writer"
      },
      {
        "command": "markdownWriter.editor.setParagraph",
        "title": "%command.editor.setParagraph.title%",
        "category": "Markdown Writer"
      },
      {
        "command": "markdownWriter.editor.setHeading1",
        "title": "%command.editor.setHeading1.title%",
        "category": "Markdown Writer"
      },
      {
        "command": "markdownWriter.editor.setHeading2",
        "title": "%command.editor.setHeading2.title%",
        "category": "Markdown Writer"
      },
      {
        "command": "markdownWriter.editor.setHeading3",
        "title": "%command.editor.setHeading3.title%",
        "category": "Markdown Writer"
      },
      {
        "command": "markdownWriter.editor.setHeading4",
        "title": "%command.editor.setHeading4.title%",
        "category": "Markdown Writer"
      },
      {
        "command": "markdownWriter.editor.setHeading5",
        "title": "%command.editor.setHeading5.title%",
        "category": "Markdown Writer"
      },
      {
        "command": "markdownWriter.editor.setHeading6",
        "title": "%command.editor.setHeading6.title%",
        "category": "Markdown Writer"
      },
      {
        "command": "markdownWriter.editor.toggleBulletList",
        "title": "%command.editor.toggleBulletList.title%",
        "category": "Markdown Writer"
      },
      {
        "command": "markdownWriter.editor.toggleOrderedList",
        "title": "%command.editor.toggleOrderedList.title%",
        "category": "Markdown Writer"
      },
      {
        "command": "markdownWriter.editor.toggleTaskList",
        "title": "%command.editor.toggleTaskList.title%",
        "category": "Markdown Writer"
      },
      {
        "command": "markdownWriter.editor.toggleBlockquote",
        "title": "%command.editor.toggleBlockquote.title%",
        "category": "Markdown Writer"
      },
      {
        "command": "markdownWriter.editor.insertCodeBlock",
        "title": "%command.editor.insertCodeBlock.title%",
        "category": "Markdown Writer"
      },
      {
        "command": "markdownWriter.editor.insertHorizontalRule",
        "title": "%command.editor.insertHorizontalRule.title%",
        "category": "Markdown Writer"
      },
      {
        "command": "markdownWriter.editor.insertTable",
        "title": "%command.editor.insertTable.title%",
        "category": "Markdown Writer"
      },
      {
        "command": "markdownWriter.editor.insertLink",
        "title": "%command.editor.insertLink.title%",
        "category": "Markdown Writer"
      },
      {
        "command": "markdownWriter.editor.insertImage",
        "title": "%command.editor.insertImage.title%",
        "category": "Markdown Writer"
      },
      {
        "command": "markdownWriter.editor.insertMath",
        "title": "%command.editor.insertMath.title%",
        "category": "Markdown Writer"
      },
      {
        "command": "markdownWriter.editor.insertFootnote",
        "title": "%command.editor.insertFootnote.title%",
        "category": "Markdown Writer"
      },
      {
        "command": "markdownWriter.editor.openFind",
        "title": "%command.editor.openFind.title%",
        "category": "Markdown Writer"
      },
      {
        "command": "markdownWriter.editor.openFindReplace",
        "title": "%command.editor.openFindReplace.title%",
        "category": "Markdown Writer"
      },
      {
        "command": "markdownWriter.editor.toggleToc",
        "title": "%command.editor.toggleToc.title%",
        "category": "Markdown Writer"
      },
      {
        "command": "markdownWriter.editor.editFrontmatter",
        "title": "%command.editor.editFrontmatter.title%",
        "category": "Markdown Writer"
      },
      {
        "command": "markdownWriter.editor.tableInsertRowAbove",
        "title": "%command.editor.tableInsertRowAbove.title%",
        "category": "Markdown Writer"
      },
      {
        "command": "markdownWriter.editor.tableInsertRowBelow",
        "title": "%command.editor.tableInsertRowBelow.title%",
        "category": "Markdown Writer"
      },
      {
        "command": "markdownWriter.editor.tableInsertColumnLeft",
        "title": "%command.editor.tableInsertColumnLeft.title%",
        "category": "Markdown Writer"
      },
      {
        "command": "markdownWriter.editor.tableInsertColumnRight",
        "title": "%command.editor.tableInsertColumnRight.title%",
        "category": "Markdown Writer"
      },
      {
        "command": "markdownWriter.editor.tableDeleteRow",
        "title": "%command.editor.tableDeleteRow.title%",
        "category": "Markdown Writer"
      },
      {
        "command": "markdownWriter.editor.tableDeleteColumn",
        "title": "%command.editor.tableDeleteColumn.title%",
        "category": "Markdown Writer"
      },
      {
        "command": "markdownWriter.editor.tableDeleteTable",
        "title": "%command.editor.tableDeleteTable.title%",
        "category": "Markdown Writer"
      },
      {
        "command": "markdownWriter.editor.copyAsHtml",
        "title": "%command.editor.copyAsHtml.title%",
        "category": "Markdown Writer"
      },
      {
        "command": "markdownWriter.editor.copyAsMarkdown",
        "title": "%command.editor.copyAsMarkdown.title%",
        "category": "Markdown Writer"
      }
    ],
    "keybindings": [
      {
        "command": "markdownWriter.switchToTextEditor",
        "key": "ctrl+shift+m",
        "mac": "cmd+shift+m",
        "when": "activeCustomEditorId == 'markdownWriter.editor'"
      },
      {
        "command": "markdownWriter.toggleStyleCheck",
        "key": "ctrl+alt+shift+d",
        "mac": "cmd+alt+shift+d",
        "when": "activeCustomEditorId == 'markdownWriter.editor'"
      },
      {
        "command": "markdownWriter.switchToPreview",
        "key": "ctrl+shift+m",
        "mac": "cmd+shift+m",
        "when": "resourceExtname == '.md' && activeCustomEditorId != 'markdownWriter.editor'"
      },
      {
        "command": "markdownWriter.gotoSymbol",
        "key": "ctrl+shift+o",
        "mac": "cmd+shift+o",
        "when": "activeCustomEditorId == 'markdownWriter.editor'"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "markdownWriter.switchToTextEditor",
          "group": "navigation",
          "when": "activeCustomEditorId == 'markdownWriter.editor'"
        },
        {
          "command": "markdownWriter.switchToPreview",
          "group": "navigation",
          "when": "resourceExtname == '.md' && activeCustomEditorId != 'markdownWriter.editor'"
        },
        {
          "command": "markdownWriter.debugModeEnable",
          "group": "9_debug",
          "when": "activeCustomEditorId == 'markdownWriter.editor' && !markdownWriter.debugModeActive"
        },
        {
          "command": "markdownWriter.debugModeDisable",
          "group": "9_debug",
          "when": "activeCustomEditorId == 'markdownWriter.editor' && markdownWriter.debugModeActive"
        }
      ],
      "commandPalette": [
        {
          "command": "markdownWriter.gotoSymbol",
          "when": "activeCustomEditorId == 'markdownWriter.editor'"
        },
        {
          "command": "markdownWriter.editor.toggleBold",
          "when": "activeCustomEditorId == 'markdownWriter.editor'"
        },
        {
          "command": "markdownWriter.editor.toggleItalic",
          "when": "activeCustomEditorId == 'markdownWriter.editor'"
        },
        {
          "command": "markdownWriter.editor.toggleStrikethrough",
          "when": "activeCustomEditorId == 'markdownWriter.editor'"
        },
        {
          "command": "markdownWriter.editor.toggleInlineCode",
          "when": "activeCustomEditorId == 'markdownWriter.editor'"
        },
        {
          "command": "markdownWriter.editor.clearFormatting",
          "when": "activeCustomEditorId == 'markdownWriter.editor'"
        },
        {
          "command": "markdownWriter.editor.setParagraph",
          "when": "activeCustomEditorId == 'markdownWriter.editor'"
        },
        {
          "command": "markdownWriter.editor.setHeading1",
          "when": "activeCustomEditorId == 'markdownWriter.editor'"
        },
        {
          "command": "markdownWriter.editor.setHeading2",
          "when": "activeCustomEditorId == 'markdownWriter.editor'"
        },
        {
          "command": "markdownWriter.editor.setHeading3",
          "when": "activeCustomEditorId == 'markdownWriter.editor'"
        },
        {
          "command": "markdownWriter.editor.setHeading4",
          "when": "activeCustomEditorId == 'markdownWriter.editor'"
        },
        {
          "command": "markdownWriter.editor.setHeading5",
          "when": "activeCustomEditorId == 'markdownWriter.editor'"
        },
        {
          "command": "markdownWriter.editor.setHeading6",
          "when": "activeCustomEditorId == 'markdownWriter.editor'"
        },
        {
          "command": "markdownWriter.editor.toggleBulletList",
          "when": "activeCustomEditorId == 'markdownWriter.editor'"
        },
        {
          "command": "markdownWriter.editor.toggleOrderedList",
          "when": "activeCustomEditorId == 'markdownWriter.editor'"
        },
        {
          "command": "markdownWriter.editor.toggleTaskList",
          "when": "activeCustomEditorId == 'markdownWriter.editor'"
        },
        {
          "command": "markdownWriter.editor.toggleBlockquote",
          "when": "activeCustomEditorId == 'markdownWriter.editor'"
        },
        {
          "command": "markdownWriter.editor.insertCodeBlock",
          "when": "activeCustomEditorId == 'markdownWriter.editor'"
        },
        {
          "command": "markdownWriter.editor.insertHorizontalRule",
          "when": "activeCustomEditorId == 'markdownWriter.editor'"
        },
        {
          "command": "markdownWriter.editor.insertTable",
          "when": "activeCustomEditorId == 'markdownWriter.editor'"
        },
        {
          "command": "markdownWriter.editor.insertLink",
          "when": "activeCustomEditorId == 'markdownWriter.editor'"
        },
        {
          "command": "markdownWriter.editor.insertImage",
          "when": "activeCustomEditorId == 'markdownWriter.editor'"
        },
        {
          "command": "markdownWriter.editor.insertMath",
          "when": "activeCustomEditorId == 'markdownWriter.editor'"
        },
        {
          "command": "markdownWriter.editor.insertFootnote",
          "when": "activeCustomEditorId == 'markdownWriter.editor'"
        },
        {
          "command": "markdownWriter.editor.openFind",
          "when": "activeCustomEditorId == 'markdownWriter.editor'"
        },
        {
          "command": "markdownWriter.editor.openFindReplace",
          "when": "activeCustomEditorId == 'markdownWriter.editor'"
        },
        {
          "command": "markdownWriter.editor.toggleToc",
          "when": "activeCustomEditorId == 'markdownWriter.editor'"
        },
        {
          "command": "markdownWriter.editor.editFrontmatter",
          "when": "activeCustomEditorId == 'markdownWriter.editor'"
        },
        {
          "command": "markdownWriter.editor.tableInsertRowAbove",
          "when": "false"
        },
        {
          "command": "markdownWriter.editor.tableInsertRowBelow",
          "when": "false"
        },
        {
          "command": "markdownWriter.editor.tableInsertColumnLeft",
          "when": "false"
        },
        {
          "command": "markdownWriter.editor.tableInsertColumnRight",
          "when": "false"
        },
        {
          "command": "markdownWriter.editor.tableDeleteRow",
          "when": "false"
        },
        {
          "command": "markdownWriter.editor.tableDeleteColumn",
          "when": "false"
        },
        {
          "command": "markdownWriter.editor.tableDeleteTable",
          "when": "false"
        },
        {
          "command": "markdownWriter.editor.copyAsHtml",
          "when": "false"
        },
        {
          "command": "markdownWriter.editor.copyAsMarkdown",
          "when": "false"
        }
      ],
      "webview/context": [
        {
          "command": "markdownWriter.editor.tableInsertRowAbove",
          "when": "webviewId == 'markdownWriter.editor' && webviewSection == 'table'",
          "group": "1_table@1"
        },
        {
          "command": "markdownWriter.editor.tableInsertRowBelow",
          "when": "webviewId == 'markdownWriter.editor' && webviewSection == 'table'",
          "group": "1_table@2"
        },
        {
          "command": "markdownWriter.editor.tableInsertColumnLeft",
          "when": "webviewId == 'markdownWriter.editor' && webviewSection == 'table'",
          "group": "1_table@3"
        },
        {
          "command": "markdownWriter.editor.tableInsertColumnRight",
          "when": "webviewId == 'markdownWriter.editor' && webviewSection == 'table'",
          "group": "1_table@4"
        },
        {
          "command": "markdownWriter.editor.tableDeleteRow",
          "when": "webviewId == 'markdownWriter.editor' && webviewSection == 'table'",
          "group": "1_table@5"
        },
        {
          "command": "markdownWriter.editor.tableDeleteColumn",
          "when": "webviewId == 'markdownWriter.editor' && webviewSection == 'table'",
          "group": "1_table@6"
        },
        {
          "command": "markdownWriter.editor.tableDeleteTable",
          "when": "webviewId == 'markdownWriter.editor' && webviewSection == 'table'",
          "group": "1_table@7"
        },
        {
          "command": "markdownWriter.editor.insertLink",
          "when": "webviewId == 'markdownWriter.editor' && webviewSection == 'link'",
          "group": "2_link@1"
        },
        {
          "command": "markdownWriter.editor.copyAsHtml",
          "when": "webviewId == 'markdownWriter.editor' && webviewSection == 'editor'",
          "group": "3_copy@1"
        },
        {
          "command": "markdownWriter.editor.copyAsMarkdown",
          "when": "webviewId == 'markdownWriter.editor' && webviewSection == 'editor'",
          "group": "3_copy@2"
        }
      ]
    },
    "configuration": {
      "title": "Markdown Writer",
      "properties": {
        "markdownWriter.autoSave": {
          "order": 2,
          "type": "boolean",
          "default": true,
          "description": "%config.autoSave.description%",
          "deprecationMessage": "Deprecated: the editor is now backed by a native text document. Use the built-in `files.autoSave` setting instead — it governs saving for this editor too."
        },
        "markdownWriter.styleCheck.enabled": {
          "order": 110,
          "type": "boolean",
          "default": false,
          "description": "%config.styleCheck.enabled.description%"
        },
        "markdownWriter.styleCheck.fillers": {
          "order": 111,
          "type": "boolean",
          "default": true,
          "description": "%config.styleCheck.fillers.description%"
        },
        "markdownWriter.styleCheck.redundancies": {
          "order": 112,
          "type": "boolean",
          "default": true,
          "description": "%config.styleCheck.redundancies.description%"
        },
        "markdownWriter.styleCheck.cliches": {
          "order": 113,
          "type": "boolean",
          "default": true,
          "description": "%config.styleCheck.cliches.description%"
        },
        "markdownWriter.styleCheck.wordiness": {
          "order": 117,
          "type": "boolean",
          "default": true,
          "description": "%config.styleCheck.wordiness.description%"
        },
        "markdownWriter.styleCheck.aiVocabulary": {
          "order": 118,
          "type": "boolean",
          "default": true,
          "description": "%config.styleCheck.aiVocabulary.description%"
        },
        "markdownWriter.styleCheck.aiArtifacts": {
          "order": 119,
          "type": "boolean",
          "default": true,
          "description": "%config.styleCheck.aiArtifacts.description%"
        },
        "markdownWriter.styleCheck.passive": {
          "order": 120,
          "type": "boolean",
          "default": true,
          "description": "%config.styleCheck.passive.description%"
        },
        "markdownWriter.styleCheck.negativeParallelism": {
          "order": 121,
          "type": "boolean",
          "default": true,
          "description": "%config.styleCheck.negativeParallelism.description%"
        },
        "markdownWriter.styleCheck.longSentences": {
          "order": 122,
          "type": "boolean",
          "default": false,
          "description": "%config.styleCheck.longSentences.description%"
        },
        "markdownWriter.styleCheck.ruleOfThree": {
          "order": 123,
          "type": "boolean",
          "default": false,
          "description": "%config.styleCheck.ruleOfThree.description%"
        },
        "markdownWriter.styleCheck.emDash": {
          "order": 124,
          "type": "boolean",
          "default": false,
          "description": "%config.styleCheck.emDash.description%"
        },
        "markdownWriter.styleCheck.nonAsciiPunct": {
          "order": 125,
          "type": "boolean",
          "default": false,
          "description": "%config.styleCheck.nonAsciiPunct.description%"
        },
        "markdownWriter.spellCheck.enabled": {
          "order": 114,
          "type": "boolean",
          "default": true,
          "description": "%config.spellCheck.enabled.description%"
        },
        "markdownWriter.spellCheck.grammar": {
          "order": 114,
          "type": "boolean",
          "default": true,
          "description": "%config.spellCheck.grammar.description%"
        },
        "markdownWriter.spellCheck.userWords": {
          "order": 115,
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "%config.spellCheck.userWords.description%"
        },
        "markdownWriter.styleCheck.exceptions": {
          "order": 116,
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "%config.styleCheck.exceptions.description%"
        },
        "markdownWriter.autoSaveDelay": {
          "order": 3,
          "type": "number",
          "default": 1000,
          "minimum": 100,
          "maximum": 10000,
          "description": "%config.autoSaveDelay.description%",
          "deprecationMessage": "Deprecated: the editor is now backed by a native text document. Use the built-in `files.autoSaveDelay` setting instead."
        },
        "markdownWriter.codeBlockMaxHeight": {
          "order": 8,
          "type": "number",
          "default": 600,
          "minimum": 100,
          "description": "%config.codeBlockMaxHeight.description%"
        },
        "markdownWriter.codeBlockAutoConvert": {
          "order": 7,
          "type": "boolean",
          "default": true,
          "description": "%config.codeBlockAutoConvert.description%"
        },
        "markdownWriter.codeBlockWordWrap": {
          "order": 9,
          "type": "string",
          "enum": [
            "inherit",
            "on",
            "off"
          ],
          "enumDescriptions": [
            "%config.codeBlockWordWrap.inherit%",
            "%config.codeBlockWordWrap.on%",
            "%config.codeBlockWordWrap.off%"
          ],
          "default": "inherit",
          "description": "%config.codeBlockWordWrap.description%"
        },
        "markdownWriter.tableWrap": {
          "order": 10,
          "type": "string",
          "enum": [
            "none",
            "normal",
            "aggressive"
          ],
          "default": "normal",
          "description": "%config.tableWrap.description%",
          "enumDescriptions": [
            "%config.tableWrap.none%",
            "%config.tableWrap.normal%",
            "%config.tableWrap.aggressive%"
          ]
        },
        "markdownWriter.defaultMode": {
          "order": 1,
          "type": "string",
          "enum": [
            "preview",
            "markdown"
          ],
          "enumDescriptions": [
            "%config.defaultMode.preview%",
            "%config.defaultMode.markdown%"
          ],
          "default": "preview",
          "description": "%config.defaultMode.description%"
        },
        "markdownWriter.editorMaxWidth": {
          "order": 4,
          "type": [
            "number",
            "string"
          ],
          "default": "auto",
          "minimum": 400,
          "description": "%config.editorMaxWidth.description%"
        },
        "markdownWriter.tocContentGap": {
          "order": 5,
          "type": "number",
          "default": 100,
          "minimum": 16,
          "maximum": 240,
          "description": "%config.tocContentGap.description%"
        },
        "markdownWriter.tocPosition": {
          "order": 5,
          "type": "string",
          "enum": [
            "left",
            "right"
          ],
          "default": "left",
          "description": "%config.tocPosition.description%",
          "enumDescriptions": [
            "%config.tocPosition.left%",
            "%config.tocPosition.right%"
          ]
        },
        "markdownWriter.customCss": {
          "order": 12,
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          },
          "description": "%config.customCss.description%"
        },
        "markdownWriter.customJs": {
          "order": 13,
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          },
          "description": "%config.customJs.description%"
        },
        "markdownWriter.fontFamily": {
          "order": 6,
          "type": "string",
          "default": "",
          "description": "%config.fontFamily.description%"
        },
        "markdownWriter.fontPreset": {
          "order": 7,
          "type": "string",
          "enum": [
            "default",
            "sans",
            "serif",
            "mono"
          ],
          "enumDescriptions": [
            "%config.fontPreset.default%",
            "%config.fontPreset.sans%",
            "%config.fontPreset.serif%",
            "%config.fontPreset.mono%"
          ],
          "default": "mono",
          "description": "%config.fontPreset.description%"
        },
        "markdownWriter.toolbar.items.format": {
          "order": 30,
          "type": "string",
          "enum": [
            "hidden",
            "left",
            "center",
            "right"
          ],
          "default": "center",
          "description": "Text level menu (paragraph, headings): pick a toolbar zone or hide it."
        },
        "markdownWriter.toolbar.items.clearFormatting": {
          "order": 31,
          "type": "string",
          "enum": [
            "hidden",
            "left",
            "center",
            "right"
          ],
          "default": "center",
          "description": "Clear formatting button: pick a toolbar zone or hide it."
        },
        "markdownWriter.toolbar.items.fontPreset": {
          "order": 32,
          "type": "string",
          "enum": [
            "hidden",
            "left",
            "center",
            "right"
