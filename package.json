{
    "name": "md-wysiwyg-editor",
    "displayName": "WYSIWYG Markdown Editor",
    "description": "WYSIWYG Markdown editor with live table editing",
    "version": "0.2.2",
    "publisher": "harlanlewis",
    "engines": {
        "vscode": "^1.80.0"
    },
    "packageManager": "pnpm@10.6.1",
    "extensionKind": [
        "workspace",
        "ui"
    ],
    "icon": "images/icon.jpg",
    "categories": [
        "Formatters",
        "Other"
    ],
    "keywords": [
        "markdown",
        "wysiwyg",
        "editor",
        "table",
        "milkdown"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/harlanlewis/md-wysiwyg-editor.git"
    },
    "bugs": {
        "url": "https://github.com/harlanlewis/md-wysiwyg-editor/issues"
    },
    "homepage": "https://github.com/harlanlewis/md-wysiwyg-editor#readme",
    "activationEvents": [],
    "main": "./dist/extension.js",
    "l10n": "./l10n",
    "contributes": {
        "customEditors": [
            {
                "viewType": "markdownWysiwyg.editor",
                "displayName": "WYSIWYG Markdown Editor",
                "selector": [
                    {
                        "filenamePattern": "*.md"
                    },
                    {
                        "filenamePattern": "*.markdown"
                    }
                ],
                "priority": "option"
            }
        ],
        "commands": [
            {
                "command": "markdownWysiwyg.switchToTextEditor",
                "title": "%command.switchToTextEditor.title%",
                "icon": "$(eye-closed)"
            },
            {
                "command": "markdownWysiwyg.switchToPreview",
                "title": "%command.switchToPreview.title%",
                "icon": "$(eye)"
            },
            {
                "command": "markdownWysiwyg.debugModeEnable",
                "title": "%command.debugModeEnable.title%"
            },
            {
                "command": "markdownWysiwyg.debugModeDisable",
                "title": "%command.debugModeDisable.title%"
            },
            {
                "command": "markdownWysiwyg.selectTheme",
                "title": "%command.selectTheme.title%"
            },
            {
                "command": "markdownWysiwyg.showCurrentTheme",
                "title": "%command.showCurrentTheme.title%"
            },
            {
                "command": "markdownWysiwyg.toggleStyleCheck",
                "title": "%command.toggleStyleCheck.title%"
            },
            {
                "command": "markdownWysiwyg.gotoSymbol",
                "title": "%command.gotoSymbol.title%"
            },
            {
                "command": "markdownWysiwyg.editor.toggleBold",
                "title": "%command.editor.toggleBold.title%",
                "category": "Markdown WYSIWYG"
            },
            {
                "command": "markdownWysiwyg.editor.toggleItalic",
                "title": "%command.editor.toggleItalic.title%",
                "category": "Markdown WYSIWYG"
            },
            {
                "command": "markdownWysiwyg.editor.toggleStrikethrough",
                "title": "%command.editor.toggleStrikethrough.title%",
                "category": "Markdown WYSIWYG"
            },
            {
                "command": "markdownWysiwyg.editor.toggleInlineCode",
                "title": "%command.editor.toggleInlineCode.title%",
                "category": "Markdown WYSIWYG"
            },
            {
                "command": "markdownWysiwyg.editor.clearFormatting",
                "title": "%command.editor.clearFormatting.title%",
                "category": "Markdown WYSIWYG"
            },
            {
                "command": "markdownWysiwyg.editor.setParagraph",
                "title": "%command.editor.setParagraph.title%",
                "category": "Markdown WYSIWYG"
            },
            {
                "command": "markdownWysiwyg.editor.setHeading1",
                "title": "%command.editor.setHeading1.title%",
                "category": "Markdown WYSIWYG"
            },
            {
                "command": "markdownWysiwyg.editor.setHeading2",
                "title": "%command.editor.setHeading2.title%",
                "category": "Markdown WYSIWYG"
            },
            {
                "command": "markdownWysiwyg.editor.setHeading3",
                "title": "%command.editor.setHeading3.title%",
                "category": "Markdown WYSIWYG"
            },
            {
                "command": "markdownWysiwyg.editor.setHeading4",
                "title": "%command.editor.setHeading4.title%",
                "category": "Markdown WYSIWYG"
            },
            {
                "command": "markdownWysiwyg.editor.setHeading5",
                "title": "%command.editor.setHeading5.title%",
                "category": "Markdown WYSIWYG"
            },
            {
                "command": "markdownWysiwyg.editor.setHeading6",
                "title": "%command.editor.setHeading6.title%",
                "category": "Markdown WYSIWYG"
            },
            {
                "command": "markdownWysiwyg.editor.toggleBulletList",
                "title": "%command.editor.toggleBulletList.title%",
                "category": "Markdown WYSIWYG"
            },
            {
                "command": "markdownWysiwyg.editor.toggleOrderedList",
                "title": "%command.editor.toggleOrderedList.title%",
                "category": "Markdown WYSIWYG"
            },
            {
                "command": "markdownWysiwyg.editor.toggleTaskList",
                "title": "%command.editor.toggleTaskList.title%",
                "category": "Markdown WYSIWYG"
            },
            {
                "command": "markdownWysiwyg.editor.toggleBlockquote",
                "title": "%command.editor.toggleBlockquote.title%",
                "category": "Markdown WYSIWYG"
            },
            {
                "command": "markdownWysiwyg.editor.insertCodeBlock",
                "title": "%command.editor.insertCodeBlock.title%",
                "category": "Markdown WYSIWYG"
            },
            {
                "command": "markdownWysiwyg.editor.insertHorizontalRule",
                "title": "%command.editor.insertHorizontalRule.title%",
                "category": "Markdown WYSIWYG"
            },
            {
                "command": "markdownWysiwyg.editor.insertTable",
                "title": "%command.editor.insertTable.title%",
                "category": "Markdown WYSIWYG"
            },
            {
                "command": "markdownWysiwyg.editor.insertLink",
                "title": "%command.editor.insertLink.title%",
                "category": "Markdown WYSIWYG"
            },
            {
                "command": "markdownWysiwyg.editor.insertImage",
                "title": "%command.editor.insertImage.title%",
                "category": "Markdown WYSIWYG"
            },
            {
                "command": "markdownWysiwyg.editor.insertMath",
                "title": "%command.editor.insertMath.title%",
                "category": "Markdown WYSIWYG"
            },
            {
                "command": "markdownWysiwyg.editor.insertFootnote",
                "title": "%command.editor.insertFootnote.title%",
                "category": "Markdown WYSIWYG"
            },
            {
                "command": "markdownWysiwyg.editor.openFind",
                "title": "%command.editor.openFind.title%",
                "category": "Markdown WYSIWYG"
            },
            {
                "command": "markdownWysiwyg.editor.openFindReplace",
                "title": "%command.editor.openFindReplace.title%",
                "category": "Markdown WYSIWYG"
            },
            {
                "command": "markdownWysiwyg.editor.toggleToc",
                "title": "%command.editor.toggleToc.title%",
                "category": "Markdown WYSIWYG"
            },
            {
                "command": "markdownWysiwyg.editor.editFrontmatter",
                "title": "%command.editor.editFrontmatter.title%",
                "category": "Markdown WYSIWYG"
            },
            {
                "command": "markdownWysiwyg.editor.tableInsertRowAbove",
                "title": "%command.editor.tableInsertRowAbove.title%",
                "category": "Markdown WYSIWYG"
            },
            {
                "command": "markdownWysiwyg.editor.tableInsertRowBelow",
                "title": "%command.editor.tableInsertRowBelow.title%",
                "category": "Markdown WYSIWYG"
            },
            {
                "command": "markdownWysiwyg.editor.tableInsertColumnLeft",
                "title": "%command.editor.tableInsertColumnLeft.title%",
                "category": "Markdown WYSIWYG"
            },
            {
                "command": "markdownWysiwyg.editor.tableInsertColumnRight",
                "title": "%command.editor.tableInsertColumnRight.title%",
                "category": "Markdown WYSIWYG"
            },
            {
                "command": "markdownWysiwyg.editor.tableDeleteRow",
                "title": "%command.editor.tableDeleteRow.title%",
                "category": "Markdown WYSIWYG"
            },
            {
                "command": "markdownWysiwyg.editor.tableDeleteColumn",
                "title": "%command.editor.tableDeleteColumn.title%",
                "category": "Markdown WYSIWYG"
            },
            {
                "command": "markdownWysiwyg.editor.copyAsHtml",
                "title": "%command.editor.copyAsHtml.title%",
                "category": "Markdown WYSIWYG"
            },
            {
                "command": "markdownWysiwyg.editor.copyAsMarkdown",
                "title": "%command.editor.copyAsMarkdown.title%",
                "category": "Markdown WYSIWYG"
            }
        ],
        "keybindings": [
            {
                "command": "markdownWysiwyg.switchToTextEditor",
                "key": "ctrl+shift+m",
                "mac": "cmd+shift+m",
                "when": "activeCustomEditorId == 'markdownWysiwyg.editor'"
            },
            {
                "command": "markdownWysiwyg.toggleStyleCheck",
                "key": "ctrl+alt+shift+d",
                "mac": "cmd+alt+shift+d",
                "when": "activeCustomEditorId == 'markdownWysiwyg.editor'"
            },
            {
                "command": "markdownWysiwyg.switchToPreview",
                "key": "ctrl+shift+m",
                "mac": "cmd+shift+m",
                "when": "resourceExtname == '.md' && activeCustomEditorId != 'markdownWysiwyg.editor'"
            },
            {
                "command": "markdownWysiwyg.gotoSymbol",
                "key": "ctrl+shift+o",
                "mac": "cmd+shift+o",
                "when": "activeCustomEditorId == 'markdownWysiwyg.editor'"
            }
        ],
        "menus": {
            "editor/title": [
                {
                    "command": "markdownWysiwyg.switchToTextEditor",
                    "group": "navigation",
                    "when": "activeCustomEditorId == 'markdownWysiwyg.editor'"
                },
                {
                    "command": "markdownWysiwyg.switchToPreview",
                    "group": "navigation",
                    "when": "resourceExtname == '.md' && activeCustomEditorId != 'markdownWysiwyg.editor'"
                },
                {
                    "command": "markdownWysiwyg.debugModeEnable",
                    "group": "9_debug",
                    "when": "activeCustomEditorId == 'markdownWysiwyg.editor' && !markdownWysiwyg.debugModeActive"
                },
                {
                    "command": "markdownWysiwyg.debugModeDisable",
                    "group": "9_debug",
                    "when": "activeCustomEditorId == 'markdownWysiwyg.editor' && markdownWysiwyg.debugModeActive"
                }
            ],
            "commandPalette": [
                {
                    "command": "markdownWysiwyg.gotoSymbol",
                    "when": "activeCustomEditorId == 'markdownWysiwyg.editor'"
                },
                {
                    "command": "markdownWysiwyg.editor.toggleBold",
                    "when": "activeCustomEditorId == 'markdownWysiwyg.editor'"
                },
                {
                    "command": "markdownWysiwyg.editor.toggleItalic",
                    "when": "activeCustomEditorId == 'markdownWysiwyg.editor'"
                },
                {
                    "command": "markdownWysiwyg.editor.toggleStrikethrough",
                    "when": "activeCustomEditorId == 'markdownWysiwyg.editor'"
                },
                {
                    "command": "markdownWysiwyg.editor.toggleInlineCode",
                    "when": "activeCustomEditorId == 'markdownWysiwyg.editor'"
                },
                {
                    "command": "markdownWysiwyg.editor.clearFormatting",
                    "when": "activeCustomEditorId == 'markdownWysiwyg.editor'"
                },
                {
                    "command": "markdownWysiwyg.editor.setParagraph",
                    "when": "activeCustomEditorId == 'markdownWysiwyg.editor'"
                },
                {
                    "command": "markdownWysiwyg.editor.setHeading1",
                    "when": "activeCustomEditorId == 'markdownWysiwyg.editor'"
                },
                {
                    "command": "markdownWysiwyg.editor.setHeading2",
                    "when": "activeCustomEditorId == 'markdownWysiwyg.editor'"
                },
                {
                    "command": "markdownWysiwyg.editor.setHeading3",
                    "when": "activeCustomEditorId == 'markdownWysiwyg.editor'"
                },
                {
                    "command": "markdownWysiwyg.editor.setHeading4",
                    "when": "activeCustomEditorId == 'markdownWysiwyg.editor'"
                },
                {
                    "command": "markdownWysiwyg.editor.setHeading5",
                    "when": "activeCustomEditorId == 'markdownWysiwyg.editor'"
                },
                {
                    "command": "markdownWysiwyg.editor.setHeading6",
                    "when": "activeCustomEditorId == 'markdownWysiwyg.editor'"
                },
                {
                    "command": "markdownWysiwyg.editor.toggleBulletList",
                    "when": "activeCustomEditorId == 'markdownWysiwyg.editor'"
                },
                {
                    "command": "markdownWysiwyg.editor.toggleOrderedList",
                    "when": "activeCustomEditorId == 'markdownWysiwyg.editor'"
                },
                {
                    "command": "markdownWysiwyg.editor.toggleTaskList",
                    "when": "activeCustomEditorId == 'markdownWysiwyg.editor'"
                },
                {
                    "command": "markdownWysiwyg.editor.toggleBlockquote",
                    "when": "activeCustomEditorId == 'markdownWysiwyg.editor'"
                },
                {
                    "command": "markdownWysiwyg.editor.insertCodeBlock",
                    "when": "activeCustomEditorId == 'markdownWysiwyg.editor'"
                },
                {
                    "command": "markdownWysiwyg.editor.insertHorizontalRule",
                    "when": "activeCustomEditorId == 'markdownWysiwyg.editor'"
                },
                {
                    "command": "markdownWysiwyg.editor.insertTable",
                    "when": "activeCustomEditorId == 'markdownWysiwyg.editor'"
                },
                {
                    "command": "markdownWysiwyg.editor.insertLink",
                    "when": "activeCustomEditorId == 'markdownWysiwyg.editor'"
                },
                {
                    "command": "markdownWysiwyg.editor.insertImage",
                    "when": "activeCustomEditorId == 'markdownWysiwyg.editor'"
                },
                {
                    "command": "markdownWysiwyg.editor.insertMath",
                    "when": "activeCustomEditorId == 'markdownWysiwyg.editor'"
                },
                {
                    "command": "markdownWysiwyg.editor.insertFootnote",
                    "when": "activeCustomEditorId == 'markdownWysiwyg.editor'"
                },
                {
                    "command": "markdownWysiwyg.editor.openFind",
                    "when": "activeCustomEditorId == 'markdownWysiwyg.editor'"
                },
                {
                    "command": "markdownWysiwyg.editor.openFindReplace",
                    "when": "activeCustomEditorId == 'markdownWysiwyg.editor'"
                },
                {
                    "command": "markdownWysiwyg.editor.toggleToc",
                    "when": "activeCustomEditorId == 'markdownWysiwyg.editor'"
                },
                {
                    "command": "markdownWysiwyg.editor.editFrontmatter",
                    "when": "activeCustomEditorId == 'markdownWysiwyg.editor'"
                },
                {
                    "command": "markdownWysiwyg.editor.tableInsertRowAbove",
                    "when": "false"
                },
                {
                    "command": "markdownWysiwyg.editor.tableInsertRowBelow",
                    "when": "false"
                },
                {
                    "command": "markdownWysiwyg.editor.tableInsertColumnLeft",
                    "when": "false"
                },
                {
                    "command": "markdownWysiwyg.editor.tableInsertColumnRight",
                    "when": "false"
                },
                {
                    "command": "markdownWysiwyg.editor.tableDeleteRow",
                    "when": "false"
                },
                {
                    "command": "markdownWysiwyg.editor.tableDeleteColumn",
                    "when": "false"
                },
                {
                    "command": "markdownWysiwyg.editor.copyAsHtml",
                    "when": "false"
                },
                {
                    "command": "markdownWysiwyg.editor.copyAsMarkdown",
                    "when": "false"
                }
            ],
            "webview/context": [
                {
                    "command": "markdownWysiwyg.editor.tableInsertRowAbove",
                    "when": "webviewId == 'markdownWysiwyg.editor' && webviewSection == 'table'",
                    "group": "1_table@1"
                },
                {
                    "command": "markdownWysiwyg.editor.tableInsertRowBelow",
                    "when": "webviewId == 'markdownWysiwyg.editor' && webviewSection == 'table'",
                    "group": "1_table@2"
                },
                {
                    "command": "markdownWysiwyg.editor.tableInsertColumnLeft",
                    "when": "webviewId == 'markdownWysiwyg.editor' && webviewSection == 'table'",
                    "group": "1_table@3"
                },
                {
                    "command": "markdownWysiwyg.editor.tableInsertColumnRight",
                    "when": "webviewId == 'markdownWysiwyg.editor' && webviewSection == 'table'",
                    "group": "1_table@4"
                },
                {
                    "command": "markdownWysiwyg.editor.tableDeleteRow",
                    "when": "webviewId == 'markdownWysiwyg.editor' && webviewSection == 'table'",
                    "group": "1_table@5"
                },
                {
                    "command": "markdownWysiwyg.editor.tableDeleteColumn",
                    "when": "webviewId == 'markdownWysiwyg.editor' && webviewSection == 'table'",
                    "group": "1_table@6"
                },
                {
                    "command": "markdownWysiwyg.editor.insertLink",
                    "when": "webviewId == 'markdownWysiwyg.editor' && webviewSection == 'link'",
                    "group": "2_link@1"
                },
                {
                    "command": "markdownWysiwyg.editor.copyAsHtml",
                    "when": "webviewId == 'markdownWysiwyg.editor' && webviewSection == 'editor'",
                    "group": "3_copy@1"
                },
                {
                    "command": "markdownWysiwyg.editor.copyAsMarkdown",
                    "when": "webviewId == 'markdownWysiwyg.editor' && webviewSection == 'editor'",
                    "group": "3_copy@2"
                }
            ]
        },
        "configuration": {
            "title": "Markdown WYSIWYG Editor",
            "properties": {
                "markdownWysiwyg.autoSave": {
                    "order": 2,
                    "type": "boolean",
                    "default": true,
                    "description": "%config.autoSave.description%",
                    "deprecationMessage": "Deprecated: the editor is now backed by a native text document. Use the built-in `files.autoSave` setting instead — it governs saving for this editor too."
                },
                "markdownWysiwyg.styleCheck.enabled": {
                    "order": 110,
                    "type": "boolean",
                    "default": false,
                    "description": "%config.styleCheck.enabled.description%"
                },
                "markdownWysiwyg.styleCheck.fillers": {
                    "order": 111,
                    "type": "boolean",
                    "default": true,
                    "description": "%config.styleCheck.fillers.description%"
                },
                "markdownWysiwyg.styleCheck.redundancies": {
                    "order": 112,
                    "type": "boolean",
                    "default": true,
                    "description": "%config.styleCheck.redundancies.description%"
                },
                "markdownWysiwyg.styleCheck.cliches": {
                    "order": 113,
                    "type": "boolean",
                    "default": true,
                    "description": "%config.styleCheck.cliches.description%"
                },
                "markdownWysiwyg.spellCheck.enabled": {
                    "order": 114,
                    "type": "boolean",
                    "default": true,
                    "description": "%config.spellCheck.enabled.description%"
                },
                "markdownWysiwyg.spellCheck.userWords": {
                    "order": 115,
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "default": [],
                    "description": "%config.spellCheck.userWords.description%"
                },
                "markdownWysiwyg.styleCheck.exceptions": {
                    "order": 116,
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "default": [],
                    "description": "%config.styleCheck.exceptions.description%"
                },
                "markdownWysiwyg.autoSaveDelay": {
                    "order": 3,
                    "type": "number",
                    "default": 1000,
                    "minimum": 100,
                    "maximum": 10000,
                    "description": "%config.autoSaveDelay.description%",
                    "deprecationMessage": "Deprecated: the editor is now backed by a native text document. Use the built-in `files.autoSaveDelay` setting instead."
                },
                "markdownWysiwyg.codeBlockMaxHeight": {
                    "order": 8,
                    "type": "number",
                    "default": 600,
                    "minimum": 100,
                    "description": "%config.codeBlockMaxHeight.description%"
                },
                "markdownWysiwyg.codeBlockAutoConvert": {
                    "order": 7,
                    "type": "boolean",
                    "default": true,
                    "description": "%config.codeBlockAutoConvert.description%"
                },
                "markdownWysiwyg.codeBlockWordWrap": {
                    "order": 9,
                    "type": "string",
                    "enum": [
                        "inherit",
                        "on",
                        "off"
                    ],
                    "enumDescriptions": [
                        "%config.codeBlockWordWrap.inherit%",
                        "%config.codeBlockWordWrap.on%",
                        "%config.codeBlockWordWrap.off%"
                    ],
                    "default": "inherit",
                    "description": "%config.codeBlockWordWrap.description%"
                },
                "markdownWysiwyg.tableWrap": {
                    "order": 10,
                    "type": "string",
                    "enum": [
                        "none",
                        "normal",
                        "aggressive"
                    ],
                    "default": "normal",
                    "description": "%config.tableWrap.description%",
                    "enumDescriptions": [
                        "%config.tableWrap.none%",
                        "%config.tableWrap.normal%",
                        "%config.tableWrap.aggressive%"
                    ]
                },
                "markdownWysiwyg.defaultMode": {
                    "order": 1,
                    "type": "string",
                    "enum": [
                        "preview",
                        "markdown"
                    ],
                    "enumDescriptions": [
                        "%config.defaultMode.preview%",
                        "%config.defaultMode.markdown%"
                    ],
                    "default": "preview",
                    "description": "%config.defaultMode.description%"
                },
                "markdownWysiwyg.editorMaxWidth": {
                    "order": 4,
                    "type": [
                        "number",
                        "string"
                    ],
                    "default": "auto",
                    "minimum": 400,
                    "description": "%config.editorMaxWidth.description%"
                },
                "markdownWysiwyg.tocContentGap": {
                    "order": 5,
                    "type": "number",
                    "default": 100,
                    "minimum": 16,
                    "maximum": 240,
                    "description": "%config.tocContentGap.description%"
                },
                "markdownWysiwyg.tocPosition": {
                    "order": 5,
                    "type": "string",
                    "enum": [
                        "left",
                        "right"
                    ],
                    "default": "left",
                    "description": "%config.tocPosition.description%",
                    "enumDescriptions": [
                        "%config.tocPosition.left%",
                        "%config.tocPosition.right%"
                    ]
                },
                "markdownWysiwyg.customCss": {
                    "order": 12,
                    "type": "array",
                    "default": [],
                    "items": {
                        "type": "string"
                    },
                    "description": "%config.customCss.description%"
                },
                "markdownWysiwyg.customJs": {
                    "order": 13,
                    "type": "array",
                    "default": [],
                    "items": {
                        "type": "string"
                    },
                    "description": "%config.customJs.description%"
                },
                "markdownWysiwyg.fontFamily": {
                    "order": 6,
                    "type": "string",
                    "default": "",
                    "description": "%config.fontFamily.description%"
                },
                "markdownWysiwyg.tocAutoHideThreshold": {
                    "order": 11,
                    "type": "number",
                    "default": 3,
                    "minimum": 0,
                    "maximum": 20,
                    "description": "%config.tocAutoHideThreshold.description%"
                },
                "markdownWysiwyg.debugMode": {
                    "order": 90,
                    "type": "boolean",
                    "default": false,
                    "description": "%config.debugMode.description%"
                },
                "markdownWysiwyg.imageStorage": {
                    "order": 100,
                    "type": "string",
                    "enum": [
                        "local",
                        "server"
                    ],
                    "enumDescriptions": [
                        "%config.imageStorage.local%",
                        "%config.imageStorage.server%"
                    ],
                    "default": "local",
                    "description": "%config.imageStorage.description%"
                },
                "markdownWysiwyg.imageLocalPath": {
                    "order": 101,
                    "type": "string",
                    "default": "",
                    "description": "%config.imageLocalPath.description%"
                },
                "markdownWysiwyg.imageServerUrl": {
                    "order": 102,
                    "type": "string",
                    "default": "",
                    "description": "%config.imageServerUrl.description%"
                },
                "markdownWysiwyg.imageServerFieldName": {
                    "order": 103,
                    "type": "string",
                    "default": "file",
                    "description": "%config.imageServerFieldName.description%"
                },
                "markdownWysiwyg.imageServerExtraParams": {
                    "order": 104,
                    "type": "string",
                    "default": "",
                    "description": "%config.imageServerExtraParams.description%"
                },
                "markdownWysiwyg.imageServerResponsePath": {
                    "order": 105,
                    "type": "string",
                    "default": "url",
                    "description": "%config.imageServerResponsePath.description%"
                },
                "markdownWysiwyg.imageSelectionColor": {
                    "order": 14,
                    "type": "string",
                    "default": "rgba(52, 211, 153, 0.6)",
                    "description": "%config.imageSelectionColor.description%"
                },
                "markdownWysiwyg.colorTheme": {
                    "order": 15,
                    "type": "string",
                    "default": "auto",
                    "description": "%config.colorTheme.description%"
                },
                "markdownWysiwyg.customThemes": {
                    "order": 16,
                    "type": "array",
                    "items": {
                        "type": "object",
                        "properties": {
                            "name": {
                                "type": "string",
                                "description": "Theme display name"
                            },
                            "colors": {
                                "type": "object",
                                "description": "Theme color definitions (VS Code color IDs as keys)",
                                "additionalProperties": {
                                    "type": "string"
                                }
                            }
                        },
                        "required": [
                            "name",
                            "colors"
                        ]
                    },
                    "default": [],
                    "description": "%config.customThemes.description%"
                }
            }
        }
    },
    "scripts": {
        "vscode:prepublish": "node esbuild.mjs --production",
